# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/tennda

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Must be a strong 256-bit (32 byte) random secret — generate with:
#   openssl rand -hex 32
JWT_SECRET=replace-with-32-byte-random-hex-string

# Token lifetimes (Go duration syntax)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h   # 7 days = 168 hours

# ─── Server ──────────────────────────────────────────────────────────────────
APP_PORT=8080

# ─── Security ────────────────────────────────────────────────────────────────
# Bcrypt cost factor — 12 is the production recommendation
BCRYPT_COST=12
